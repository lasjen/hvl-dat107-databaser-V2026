<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">

  <!-- Named simple types -->
  <xs:simpleType name="PersonIdType">
     <xs:restriction base="xs:ID">
        <xs:pattern value="[h,d]{1}[0-9]{4}"/>
     </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PoengType">
    <xs:restriction base="xs:decimal">
       <xs:minInclusive value="0.0"/>
       <xs:maxInclusive value="3000.0"/>
    </xs:restriction>
  </xs:simpleType>

  <xs:simpleType name="PuljeType">
    <xs:restriction base="xs:integer">
      <xs:minInclusive value="1"/>
      <xs:maxInclusive value="5"/>
    </xs:restriction>
  </xs:simpleType>

  <!-- Named complex types -->
  <xs:complexType name="PersonType">
    <xs:sequence>
      <xs:element name="id" type="PersonIdType"/>
      <xs:element name="navn" type="xs:string"/>
      <xs:element name="fdato" type="xs:date"/>
      <xs:element name="medlem" type="xs:boolean"/>
      <xs:element name="poeng" type="PoengType"/>
      <xs:element name="hjemmeside" type="xs:anyURI"/>
      <xs:element name="pulje" type="PuljeType"/>
      <xs:element name="starttid" type="xs:dateTime"/>
      <xs:element name="foresattId" type="xs:IDREF" minOccurs="0"/>
    </xs:sequence>
  </xs:complexType>

  <xs:complexType name="BirkenType">
    <xs:sequence>
      <xs:element name="person" type="PersonType" maxOccurs="unbounded"/>
    </xs:sequence>
  </xs:complexType>

  <!-- Root elements -->
  <xs:element name="person" type="PersonType"/>
  <xs:element name="birken" type="BirkenType"/>
</xs:schema>

